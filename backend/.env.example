DEBUG=True
SECRET_KEY=change-me
PUBLIC_API_HOST=127.0.0.1
PUBLIC_API_ORIGIN=http://127.0.0.1:8000
CORS_ALLOW_ALL_ORIGINS=True
DATABASE_NAME=vibe_studying
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
JWT_SECRET_KEY=change-me-too
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
ENABLE_PUBLIC_TEACHER_SIGNUP=True
# Leave blank to auto-pick SMTP when EMAIL_HOST_USER and EMAIL_HOST_PASSWORD are set.
EMAIL_BACKEND=
DEFAULT_FROM_EMAIL=noreply@vibestudying.local
SERVER_EMAIL=noreply@vibestudying.local
EMAIL_TIMEOUT=10
EMAIL_HOST=localhost
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
LOG_LEVEL=INFO
APP_LOG_LEVEL=INFO
DJANGO_REQUEST_LOG_LEVEL=WARNING
USE_X_FORWARDED_HOST=False
PUBLIC_WEB_URL=http://localhost:8080
RUNTIME_ENVIRONMENT=development
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Minimal local mode without Redis:
REDIS_URL=
CACHE_URL=
CELERY_BROKER_URL=memory://
CELERY_RESULT_BACKEND=cache+memory://

# Full local stack with Redis:
# REDIS_URL=redis://127.0.0.1:6379/0
# CACHE_URL=redis://127.0.0.1:6379/1
# CELERY_BROKER_URL=redis://127.0.0.1:6379/0
# CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_EAGER_PROPAGATES=False
CACHE_DEFAULT_TIMEOUT_SECONDS=300
PUBLIC_FEED_CACHE_TIMEOUT_SECONDS=300
LESSON_DETAIL_CACHE_TIMEOUT_SECONDS=600
REMINDER_INACTIVITY_HOURS=24
OPERATIONS_ALERTS_ENABLED=True
ALERT_EMAIL_RECIPIENTS=
OPERATIONS_PENDING_EMAIL_MINUTES=15
OPERATIONS_PENDING_EMAIL_THRESHOLD=10
OPERATIONS_FAILED_EMAIL_THRESHOLD=3
OPERATIONS_PENDING_SUBMISSION_HOURS=6
OPERATIONS_PENDING_SUBMISSION_THRESHOLD=10
